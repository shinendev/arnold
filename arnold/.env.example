CLAUDE_API_KEY=
# Sonnet for high-volume background + chat. Use Opus only for rare deep passes (cost).
CLAUDE_MODEL=claude-sonnet-4-20250514
ARNOLD_DB_PATH=./arnold-memory.db
ARNOLD_USERS_DIR=./data/users
ARNOLD_ENABLE_GLOBAL_MEMORY=true
ARNOLD_IDLE_THRESHOLD_MS=300000
ARNOLD_CYCLE_INTERVAL_MS=180000
ARNOLD_ASSOCIATION_SAMPLE_SIZE=5
ARNOLD_DECAY_RATE=0.005
PORT=3210

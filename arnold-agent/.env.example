TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

ARNOLD_DB_PATH=./arnold-agent-memory.db
ARNOLD_IDLE_THRESHOLD_MS=300000
ARNOLD_CYCLE_INTERVAL_MS=180000
ARNOLD_ASSOCIATION_SAMPLE_SIZE=5
ARNOLD_DECAY_RATE=0.005

PAUSE_BOT=false
# Persists Twitter mention cursor across restarts
ARNOLD_MENTION_CURSOR_FILE=./.mention-cursor

# Twitter pacing (personality-first)
# Total tweets + replies per day (clamped 3–10 in code; default 5)
ARNOLD_MAX_TWEETS_PER_DAY=5
# Max public replies per day (replies also count toward total above)
ARNOLD_MAX_REPLY_TWEETS_PER_DAY=2
# Set true for rare “state / stats” posts (default off)
ARNOLD_POST_PROCESS_UPDATES=false
ARNOLD_PROCESS_UPDATE_INTERVAL_MS=172800000
# How often to poll mentions / check undelivered insights (ms)
ARNOLD_MENTION_CHECK_INTERVAL_MS=240000
ARNOLD_INSIGHT_CHECK_INTERVAL_MS=600000
ARNOLD_MIN_INSIGHT_CONFIDENCE=0.75
